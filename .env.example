# Chemin host pour la persistance (DB SQLite).
# Le dossier doit exister et être accessible en écriture par l'UID utilisé
# dans le conteneur (root par défaut).
DATA_DIR=/mnt/user/appdata/5sproject

# Fuseau horaire du conteneur.
TZ=Europe/Paris

# Mettre à "1" si l'app est servie derrière un reverse proxy HTTPS externe
# qui ne transmet pas X-Forwarded-Proto=https.
TRUST_PROXY_HTTPS=0
